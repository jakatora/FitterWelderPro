default_platform(:ios)

platform :ios do
  desc "Build and upload FitterWelder Pro to TestFlight/App Store Connect"
  lane :release do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_filepath: ENV.fetch("APP_STORE_CONNECT_KEY_PATH"),
      duration: 1200,
      in_house: false
    )

    # Pin signing settings to the Runner target ONLY, before build_app runs.
    # The earlier approach pushed CODE_SIGN_STYLE / PROVISIONING_PROFILE_SPECIFIER
    # globally via xcargs which xcodebuild applied to every target in the
    # workspace — including SPM-managed Flutter plugins (sqflite_darwin,
    # shared_preferences_foundation, image_picker_ios, url_launcher_ios).
    # SPM packages are libraries, not apps; they don't support provisioning
    # profiles and reject the override with:
    #   "<plugin> does not support provisioning profiles, but provisioning
    #    profile FitterWelderPro_AppStore has been manually specified."
    # update_code_signing_settings writes the values directly into
    # Runner.xcodeproj's PBXNativeTarget Runner attributes, scoped to the
    # Runner target — SPM packages keep their default Automatic style.
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Runner.xcodeproj",
      team_id: ENV.fetch("APPLE_TEAM_ID"),
      code_sign_identity: "Apple Distribution",
      bundle_identifier: ENV.fetch("APP_BUNDLE_IDENTIFIER"),
      profile_name: ENV.fetch("APP_PROVISIONING_PROFILE_NAME"),
      targets: ["Runner"]
    )

    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      clean: true,
      output_directory: "build/ios",
      output_name: "cut-list-app.ipa",
      buildlog_path: "build/xcodebuild_logs",
      # xcargs only carry the FLUTTER_ROOT pass-through needed by Flutter's
      # Run Script build phase. NO signing settings here — those live in
      # Runner.xcodeproj (set above) so xcodebuild doesn't propagate them
      # to SPM targets.
      xcargs: {
        "FLUTTER_ROOT" => ENV.fetch("FLUTTER_ROOT"),
      },
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        teamID: ENV.fetch("APPLE_TEAM_ID"),
        provisioningProfiles: {
          ENV.fetch("APP_BUNDLE_IDENTIFIER") => ENV.fetch("APP_PROVISIONING_PROFILE_NAME")
        },
        uploadSymbols: true,
        uploadBitcode: false
      }
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: "build/ios/cut-list-app.ipa",
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      changelog: ENV["TESTFLIGHT_CHANGELOG"] || "Automated build upload"
    )
  end
end
