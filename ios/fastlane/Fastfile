default_platform(:ios)

def required_env!(name)
  value = ENV[name].to_s.strip
  UI.user_error!("Missing required environment variable: #{name}") if value.empty?
  value
end

def resolve_flutter_root
  configured = ENV["FLUTTER_ROOT"].to_s.strip
  return configured unless configured.empty?

  flutter_bin = sh("which flutter").to_s.strip
  UI.user_error!("FLUTTER_ROOT is not set and Flutter was not found in PATH") if flutter_bin.empty?

  File.dirname(File.dirname(flutter_bin))
end

def build_api_key
  options = {
    key_id: required_env!("APP_STORE_CONNECT_KEY_ID"),
    issuer_id: required_env!("APP_STORE_CONNECT_ISSUER_ID"),
    duration: 1200,
    in_house: false
  }

  key_content = ENV["APP_STORE_CONNECT_PRIVATE_KEY"].to_s.strip
  key_path = ENV["APP_STORE_CONNECT_KEY_PATH"].to_s.strip

  if !key_content.empty?
    options[:key_content] = key_content
    options[:is_key_content_base64] = !key_content.start_with?("-----BEGIN")
  elsif !key_path.empty?
    options[:key_filepath] = key_path
  else
    UI.user_error!("Set APP_STORE_CONNECT_PRIVATE_KEY or APP_STORE_CONNECT_KEY_PATH")
  end

  app_store_connect_api_key(**options)
end

def export_options_for(bundle_id, team_id)
  # FIX: Always use signingStyle "automatic" for export.
  # With "manual" Xcode attempts to assign provisioning profiles to every
  # embedded binary — including Flutter plugin frameworks such as
  # file_picker.framework — which do not support provisioning profiles and
  # causes the build to fail with:
  #   "exportArchive: file_picker.framework does not support provisioning profiles"
  #
  # "automatic" tells xcodebuild to resolve identities from the local keychain
  # (the cert + profile installed earlier in the workflow) without trying to
  # provision frameworks.
  {
    method: "app-store",
    signingStyle: "automatic",
    teamID: team_id,
    uploadSymbols: true,
    uploadBitcode: false
  }
end

platform :ios do
  desc "Build and upload FitterWelder Pro to TestFlight/App Store Connect"
  lane :release do
    bundle_id = required_env!("APP_BUNDLE_IDENTIFIER")
    team_id = required_env!("APPLE_TEAM_ID")
    flutter_root = resolve_flutter_root
    profile_name = ENV["APP_PROVISIONING_PROFILE_NAME"].to_s.strip
    profile_uuid = ENV["PROFILE_UUID"].to_s.strip
    api_key = build_api_key

    # FIX: Use a Hash for xcargs so Fastlane/gym properly shell-escapes each
    # value.  The old Array.join(" ") approach broke profile names that contain
    # spaces (e.g. "FitterWelder Pro AppStore") by splitting them into separate
    # unrecognised xcodebuild arguments.
    #
    # FIX: Override CODE_SIGN_IDENTITY to "Apple Distribution" so it matches
    # the distribution certificate installed in the CI keychain.  The Xcode
    # project file sets this to "iPhone Developer" (development), which would
    # cause a code-signing identity mismatch during the archive step.
    xcargs = {
      "DEVELOPMENT_TEAM" => team_id,
      "PRODUCT_BUNDLE_IDENTIFIER" => bundle_id,
      "FLUTTER_ROOT" => flutter_root
    }

    if !profile_name.empty? || !profile_uuid.empty?
      xcargs["CODE_SIGN_STYLE"]                = "Manual"
      xcargs["CODE_SIGN_IDENTITY"]             = "Apple Distribution"
      xcargs["PROVISIONING_PROFILE_SPECIFIER"] = profile_name unless profile_name.empty?
      xcargs["PROVISIONING_PROFILE"]           = profile_uuid unless profile_uuid.empty?
    else
      xcargs["CODE_SIGN_STYLE"] = "Automatic"
    end

    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      clean: true,
      output_directory: "build/ios",
      output_name: "cut-list-app.ipa",
      buildlog_path: "build/xcodebuild_logs",
      xcargs: xcargs,
      export_options: export_options_for(bundle_id, team_id)
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: bundle_id,
      ipa: "build/ios/cut-list-app.ipa",
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      changelog: ENV["TESTFLIGHT_CHANGELOG"] || "Automated build upload"
    )
  end
end
