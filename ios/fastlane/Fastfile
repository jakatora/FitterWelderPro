default_platform(:ios)

platform :ios do
  desc "Build and upload FitterWelder Pro to TestFlight/App Store Connect"
  lane :release do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_filepath: ENV.fetch("APP_STORE_CONNECT_KEY_PATH"),
      duration: 1200,
      in_house: false
    )

    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store-connect",
      clean: true,
      output_directory: "build/ios",
      output_name: "cut-list-app.ipa",
      buildlog_path: "build/xcodebuild_logs",
      xcargs: {
        "DEVELOPMENT_TEAM"               => ENV.fetch("APPLE_TEAM_ID"),
        "PRODUCT_BUNDLE_IDENTIFIER"      => ENV.fetch("APP_BUNDLE_IDENTIFIER"),
        "CODE_SIGN_STYLE"                => "Manual",
        "CODE_SIGN_IDENTITY"             => "Apple Distribution",
        "PROVISIONING_PROFILE_SPECIFIER" => ENV.fetch("APP_PROVISIONING_PROFILE_NAME"),
        "FLUTTER_ROOT"                   => ENV.fetch("FLUTTER_ROOT"),
      },
      export_options: {
        method: "app-store-connect",
        signingStyle: "automatic",
        teamID: ENV.fetch("APPLE_TEAM_ID"),
        uploadSymbols: true,
        uploadBitcode: false
      }
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: "build/ios/cut-list-app.ipa",
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      changelog: ENV["TESTFLIGHT_CHANGELOG"] || "Automated build upload"
    )
  end
end
